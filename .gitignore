# Build output — `go build` emits binaries; keep them out of the repo.
/lazyplanner
/cmd/lazyplanner/lazyplanner

# Go workspace files (machine-local, never committed)
go.work
go.work.sum

# Test / coverage output
*.out
coverage.txt

# Editor and OS cruft
*.swp
*~
.DS_Store

# Claude Code settings are committed so they sync across machines. The global
# git ignore hides settings.local.json (Claude's auto-saved "always allow"
# grants); re-include it here so those get committed too.
!.claude/settings.local.json
